# =============================================================================
# Semantic Code Search Engine — Environment Configuration
# =============================================================================
# Copy this file to `.env` and fill in the values.
# All backend variables use the SSE_ prefix (see app/config.py).
# Frontend variables use the VITE_ prefix (see frontend/.env).

# ── LLM / RAG Configuration (Required for POST /api/v1/ask) ────────────────

# Your OpenAI API key (or compatible provider key)
SSE_OPENAI_API_KEY=sk-your-api-key-here

# Optional: custom base URL for OpenAI-compatible providers
# Examples:
#   - OpenRouter:    https://openrouter.ai/api/v1
#   - Azure OpenAI:  https://YOUR_RESOURCE.openai.azure.com/openai/deployments/YOUR_DEPLOYMENT
#   - Local Ollama:  http://localhost:11434/v1
# SSE_OPENAI_BASE_URL=

# LLM model to use (default: gpt-4o-mini)
# SSE_LLM_MODEL=gpt-4o-mini

# Sampling temperature (0.0 = deterministic, 1.0 = creative; default: 0.1)
# SSE_LLM_TEMPERATURE=0.1

# Max tokens in LLM response (default: 1024)
# SSE_LLM_MAX_TOKENS=1024

# Number of code chunks to retrieve for context (default: 5)
# SSE_RAG_TOP_K=5

# ── Embedding Model ───────────────────────────────────────────────────────
# SSE_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── ChromaDB ──────────────────────────────────────────────────────────────
# SSE_CHROMA_PERSIST_DIR=./chroma_store
# SSE_CHROMA_COLLECTION=code_chunks

# ── CORS (JSON array of allowed origins) ──────────────────────────────────
# SSE_CORS_ORIGINS=["*"]

# ── Frontend ──────────────────────────────────────────────────────────────
# Set this in frontend/.env or as VITE_API_URL build arg for Docker
# VITE_API_URL=http://localhost:8000
